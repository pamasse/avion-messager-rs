<?xml version="1.0" encoding="utf-8"?>
<!-- Installateur MSI par utilisateur — commandes de build et variante interne :
     voir README.md § « Installateur MSI ». -->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">
  <!-- Version = celle de Cargo.toml : bumper les deux ensemble (MajorUpgrade s'y fie). -->
  <Package Name="Avion Messager"
           Manufacturer="Pierre-Aymeric MASSE"
           Version="0.1.0"
           UpgradeCode="E447C646-13A2-47BB-8677-C10C01FBFC50"
           Scope="perUser"
           Compressed="yes">

    <!-- AllowSameVersionUpgrades : sans lui, un MSI public et un MSI interne de
         même version s'installeraient côte à côte (deux entrées « Applications
         installées »). -->
    <MajorUpgrade AllowSameVersionUpgrades="yes"
                  DowngradeErrorMessage="Une version plus récente d'Avion Messager est déjà installée." />
    <MediaTemplate EmbedCab="yes" />

    <!-- L'app est un process tray résident (autostart) : la fermer proprement
         avant mise à niveau / désinstallation, sinon dialogue « fichiers en
         cours d'utilisation » ou redémarrage requis. -->
    <util:CloseApplication Id="CloseAvion" Target="avion-messager.exe"
                           CloseMessage="no" TerminateProcess="0" RebootPrompt="no" />

    <!-- %LOCALAPPDATA%\Programs\Avion Messager\avion-messager.exe -->
    <StandardDirectory Id="LocalAppDataFolder">
      <Directory Id="ProgramsDir" Name="Programs">
        <Directory Id="INSTALLFOLDER" Name="Avion Messager">
          <!-- GUID explicites : WiX (WIX0230) interdit les GUID auto quand un
               composant mêle keypath registre + fichier, cas imposé par
               l'installation par-utilisateur. -->
          <Component Id="MainExe" Guid="7A3E12C4-9B0D-4A6E-B1F2-5D8C3E7F0A91">
            <!-- Emplacement par utilisateur : MSI exige un KeyPath registre HKCU -->
            <RegistryValue Root="HKCU" Key="Software\com.pierre.avionmessager"
                           Name="install" Type="string" Value="[INSTALLFOLDER]" KeyPath="yes" />
            <File Id="AvionExe" Source="target\release\avion-messager.exe" Name="avion-messager.exe" />
            <RemoveFolder Id="RemoveInstallFolder" Directory="INSTALLFOLDER" On="uninstall" />
            <RemoveFolder Id="RemoveProgramsDir" Directory="ProgramsDir" On="uninstall" />
          </Component>
          <!-- Entrée de démarrage auto possédée par le MSI : nettoyée à la
               désinstallation (l'app la gère ensuite selon le réglage
               `autostart` — même clé/valeur que src/autostart.rs). -->
          <Component Id="AutostartRun" Guid="4C8F2D96-1B7A-4E53-9C08-6D2A8F41B7E3">
            <RegistryValue Root="HKCU" Key="Software\Microsoft\Windows\CurrentVersion\Run"
                           Name="Avion Messager" Type="string"
                           Value="&quot;[INSTALLFOLDER]avion-messager.exe&quot;" KeyPath="yes" />
          </Component>
        </Directory>
      </Directory>
    </StandardDirectory>

    <!-- Raccourci menu Démarrer -->
    <StandardDirectory Id="ProgramMenuFolder">
      <Component Id="StartMenuShortcut" Guid="0F5B8D2A-6C41-4E9B-A7D3-2B9E4C1F6A58">
        <RegistryValue Root="HKCU" Key="Software\com.pierre.avionmessager"
                       Name="shortcut" Type="integer" Value="1" KeyPath="yes" />
        <Shortcut Id="AppShortcut" Name="Avion Messager"
                  Description="Un avion annonce ta prochaine réunion"
                  Target="[INSTALLFOLDER]avion-messager.exe"
                  WorkingDirectory="INSTALLFOLDER" />
      </Component>
    </StandardDirectory>

    <!-- Lance l'app en fin d'installation (et de mise à niveau) : sans ça,
         rien ne tourne avant la prochaine ouverture de session. Pas lancée
         à la désinstallation (NOT Installed est faux). -->
    <CustomAction Id="LaunchApp" FileRef="AvionExe" ExeCommand="" Return="asyncNoWait" />
    <InstallExecuteSequence>
      <Custom Action="LaunchApp" After="InstallFinalize" Condition="NOT Installed" />
    </InstallExecuteSequence>

    <?ifdef IncludeClientConfig ?>
    <!-- Build interne uniquement : dépose les identifiants OAuth là où l'app
         les cherche en premier (%APPDATA%\com.pierre.avionmessager\). -->
    <StandardDirectory Id="AppDataFolder">
      <Directory Id="AppConfigDir" Name="com.pierre.avionmessager">
        <!-- Permanent : survit aux mises à niveau (y compris par le MSI public,
             qui sinon supprimerait les identifiants de toute l'équipe) et à la
             désinstallation. -->
        <Component Id="ClientConfig" Guid="9D4A7B31-2E85-4C6F-8A19-7F3B5D0C2E64" Permanent="yes">
          <RegistryValue Root="HKCU" Key="Software\com.pierre.avionmessager"
                         Name="client_config" Type="integer" Value="1" KeyPath="yes" />
          <File Id="ClientConfigJson" Source="client_config.json" Name="client_config.json" />
        </Component>
      </Directory>
    </StandardDirectory>
    <?endif?>

  </Package>
</Wix>
